{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clauding-thought.dev/manifest.schema.json",
  "title": "Clauding Thought Manifest",
  "description": "Project DNA — describes the stack, architecture, conventions, and boundaries of a codebase so that AI agents can generate code that fits.",
  "type": "object",
  "required": ["version", "stack", "architecture", "conventions"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Manifest schema version. 1.1 adds path-scoped rules, severity levels, exports, and packs."
    },
    "project": {
      "type": "object",
      "description": "Basic project metadata",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "repo": { "type": "string", "format": "uri" }
      }
    },
    "governance": {
      "type": "object",
      "description": "Versioning and metadata for the governance layer itself",
      "properties": {
        "version": {
          "type": "string",
          "description": "Semantic version of the governance layer (e.g., '1.2.0')",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "initialized": {
          "type": "string",
          "format": "date",
          "description": "Date the governance layer was first generated by /init"
        },
        "last_evolved": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Date of the most recent /evolve run. Null for projects that have not yet evolved."
        },
        "changelog": {
          "type": "string",
          "description": "Path to the changelog file relative to .claude/",
          "default": "CHANGELOG.md"
        },
        "auto_accept": {
          "type": "boolean",
          "default": false,
          "description": "When true, .claude/settings.json is generated with all tools auto-accepted. Governance hooks (secret-filter, destructive-guard) remain active as the safety layer."
        },
        "deferred_threshold": {
          "type": "integer",
          "default": 3,
          "minimum": 0,
          "description": "Max number of open [deferred:TASK-ID] items across tasks before close-task and the deferral-check hook refuse new closures. Raise if the project has legitimate multi-sprint work in flight. Only consulted when governance.enforcement.ledger is true."
        },
        "enforcement": {
          "type": "object",
          "description": "Opt-in gates for task-doc-convention enforcement. All default to false so the plugin does not impose conventions on projects that have not declared them. /init asks the user during setup.",
          "properties": {
            "deferred_format": {
              "type": "boolean",
              "default": false,
              "description": "When true, the deferral-check hook rejects free-text 'deferred/follow-up task' phrasings in acceptance-criteria checkboxes and requires the `[deferred:TASK-ID]` form where TASK-ID resolves to a real task."
            },
            "ledger": {
              "type": "boolean",
              "default": false,
              "description": "When true, the deferral-check hook refuses closures when the project-wide count of open [deferred:TASK-ID] items (excluding the closing task's own) exceeds governance.deferred_threshold."
            },
            "criteria_format": {
              "type": "boolean",
              "default": false,
              "description": "When true, the anti-rationalization hook ignores negation patterns (I'll fix this later) and blocks dismissal language whenever the active task doc has any unchecked [ ] acceptance criteria."
            }
          }
        },
        "exports": {
          "type": "object",
          "description": "Tracks which tool exports exist and when they were last generated by /export",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "exported_at": { "type": "string", "format": "date", "description": "Date of last export" },
              "governance_version": { "type": "string", "description": "Governance version at time of export" }
            }
          }
        },
        "packs": {
          "type": "array",
          "description": "Community rule packs applied to this project",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Pack identifier (matches directory name in packs/)" },
              "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "Version of the pack that was applied" },
              "applied": { "type": "string", "format": "date", "description": "Date the pack was applied or last updated" },
              "customized": { "type": "boolean", "default": false, "description": "Whether the user has modified pack-contributed rule sections" }
            },
            "required": ["name", "version", "applied"]
          },
          "default": []
        }
      }
    },
    "task_docs": {
      "type": "object",
      "description": "Configuration for per-task documentation",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether to create task documents for significant changes"
        },
        "directory": {
          "type": "string",
          "default": "tasks",
          "description": "Directory under .claude/ where task documents are stored"
        },
        "auto_create_threshold": {
          "type": "object",
          "description": "When to automatically create a task document",
          "properties": {
            "min_files": {
              "type": "integer",
              "default": 3,
              "description": "Create doc when this many files will be modified"
            },
            "always_for": {
              "type": "array",
              "description": "Always create docs for these change types",
              "items": { "type": "string" },
              "default": ["migration", "security", "new-route", "cross-module"]
            }
          }
        },
        "promote_lessons": {
          "type": "boolean",
          "default": true,
          "description": "Auto-promote task lessons learned to memory/MEMORY.md on close"
        },
        "checkpoint_interval": {
          "type": "integer",
          "default": 30,
          "minimum": 10,
          "description": "Number of user prompts between checkpoint suggestions. The skill-reminder hook tracks prompt count and suggests running /qc --checkpoint after this many prompts."
        }
      }
    },
    "stack": {
      "type": "object",
      "description": "Technology stack detection results",
      "required": ["language", "framework"],
      "properties": {
        "language": {
          "type": "string",
          "description": "Primary language",
          "examples": ["php", "typescript", "python", "go", "rust", "java"]
        },
        "language_version": {
          "type": "string",
          "examples": ["8.4", "5.5", "3.12", "1.22"]
        },
        "framework": {
          "type": "string",
          "description": "Primary backend framework",
          "examples": ["laravel", "nextjs", "django", "gin", "rails", "spring"]
        },
        "framework_version": {
          "type": "string",
          "examples": ["12", "15", "5.1"]
        },
        "frontend": {
          "type": "string",
          "description": "Frontend framework if applicable",
          "examples": ["vue3", "react", "svelte", "htmx", "blade", "none"]
        },
        "bridge": {
          "type": "string",
          "description": "Backend-frontend bridge layer",
          "examples": ["inertia-v2", "api-rest", "graphql", "livewire", "trpc", "none"]
        },
        "css": {
          "type": "string",
          "examples": ["tailwind-v4", "tailwind-v3", "scss", "css-modules", "styled-components"]
        },
        "testing": {
          "type": "string",
          "examples": ["pest-v4", "phpunit", "jest", "vitest", "pytest", "go-test"]
        },
        "db": {
          "type": "string",
          "examples": ["postgresql", "mysql", "sqlite", "mongodb", "none"]
        },
        "orm": {
          "type": "string",
          "examples": ["eloquent", "prisma", "django-orm", "gorm", "sqlalchemy", "drizzle"]
        },
        "packages": {
          "type": "object",
          "description": "Key packages/dependencies with versions. Informational metadata — provides context for human review and /evolve dependency analysis.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "architecture": {
      "type": "object",
      "description": "Architectural decisions and patterns detected in the codebase",
      "properties": {
        "tenancy": {
          "type": "object",
          "description": "Multi-tenancy strategy",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["column-scoped", "db-per-tenant", "schema-per-tenant", "subdomain", "none"],
              "description": "How tenant isolation is achieved"
            },
            "scope_column": {
              "type": "string",
              "description": "Column name used for scoping (e.g., 'organization_id', 'tenant_id')",
              "examples": ["organization_id", "tenant_id", "team_id", "company_id"]
            },
            "trait": {
              "type": "string",
              "description": "Trait/mixin that models use for tenancy",
              "examples": ["HasOrganization", "BelongsToTenant", "Scoped"]
            },
            "trait_path": {
              "type": "string",
              "description": "Fully qualified path to the tenancy trait",
              "examples": ["App\\Models\\Concerns\\HasOrganization"]
            },
            "global_scope": {
              "type": "boolean",
              "description": "Whether tenancy uses a global query scope"
            }
          }
        },
        "auth": {
          "type": "object",
          "description": "Authentication and authorization architecture",
          "properties": {
            "authentication": {
              "type": "string",
              "enum": ["session", "token", "jwt", "oauth", "api-key"],
              "description": "How users authenticate"
            },
            "authorization": {
              "type": "object",
              "description": "How permissions and access control work",
              "properties": {
                "strategy": {
                  "type": "string",
                  "enum": ["policy", "gate", "middleware", "rbac-package", "abac", "mixed"],
                  "description": "Primary authorization pattern"
                },
                "patterns": {
                  "type": "array",
                  "description": "All authorization patterns in use with their scopes",
                  "items": {
                    "type": "object",
                    "properties": {
                      "pattern": { "type": "string" },
                      "scope": { "type": "string" },
                      "example": { "type": "string" }
                    }
                  }
                },
                "owner_bypass": {
                  "type": "boolean",
                  "description": "Whether owners/admins bypass permission checks"
                }
              }
            }
          }
        },
        "layers": {
          "type": "object",
          "description": "Application layer architecture",
          "properties": {
            "routing": { "type": "string", "description": "Where routes are defined" },
            "middleware": { "type": "string", "description": "Where middleware is registered" },
            "controllers": { "type": "string", "description": "Controller directory and style" },
            "services": { "type": "string", "description": "Service layer location (if any)" },
            "models": { "type": "string", "description": "Model/entity directory" },
            "validation": {
              "type": "string",
              "enum": ["form-request", "inline", "dto", "schema"],
              "description": "Primary validation approach"
            },
            "business_logic_location": {
              "type": "string",
              "enum": ["service", "action", "controller", "model", "command"],
              "description": "Where business logic primarily lives"
            }
          }
        },
        "api_style": {
          "type": "string",
          "enum": ["inertia-resources", "json-api", "rest-plain", "graphql", "grpc", "trpc"],
          "description": "How the backend serves data to clients"
        },
        "modules": {
          "type": "array",
          "description": "Application modules/domains detected",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "file_storage": {
          "type": "object",
          "description": "File storage configuration. Populated by /init when filesystem/storage config is detected (e.g., filesystem.php, S3 config).",
          "properties": {
            "disk": { "type": "string", "examples": ["private", "public", "s3"] },
            "auth_required": { "type": "boolean" }
          }
        }
      }
    },
    "conventions": {
      "type": "object",
      "description": "Code style and convention choices specific to this project",
      "properties": {
        "controller_auth": {
          "type": "string",
          "enum": ["per-method", "constructor", "middleware-only"],
          "description": "Where authorization checks happen in controllers"
        },
        "validation_style": {
          "type": "string",
          "enum": ["form-request-array", "form-request-string", "inline", "dto"],
          "description": "How validation rules are defined"
        },
        "model_casts": {
          "type": "string",
          "enum": ["method", "property"],
          "description": "Whether casts are defined as a method or property"
        },
        "enum_labels": {
          "type": "string",
          "enum": ["translation-key", "hardcoded", "method"],
          "description": "How enum display labels are provided"
        },
        "test_data": {
          "type": "string",
          "enum": ["factory", "manual", "fixture", "faker-inline"],
          "description": "How test data is created"
        },
        "translation": {
          "type": "object",
          "properties": {
            "system": {
              "type": "string",
              "enum": ["nested-json", "flat-json", "php-files", "i18next", "intl", "none"]
            },
            "locales": {
              "type": "array",
              "items": { "type": "string" },
              "examples": [["en", "fi", "sv", "de"]]
            },
            "all_locales_required": { "type": "boolean" }
          }
        },
        "naming": {
          "type": "object",
          "properties": {
            "files": { "type": "string", "enum": ["PascalCase", "camelCase", "kebab-case", "snake_case"] },
            "classes": { "type": "string", "enum": ["PascalCase", "camelCase"] },
            "methods": { "type": "string", "enum": ["camelCase", "snake_case"] },
            "db_columns": { "type": "string", "enum": ["snake_case", "camelCase"] },
            "routes": { "type": "string", "enum": ["kebab-case", "snake_case", "camelCase"] }
          }
        },
        "formatting": {
          "type": "object",
          "properties": {
            "tool": { "type": "string", "examples": ["pint", "prettier", "black", "gofmt", "rustfmt"] },
            "command": { "type": "string", "examples": ["php vendor/bin/pint --dirty", "npx prettier --write"] }
          }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "description": "Module dependency rules — which modules can import from which",
      "properties": {
        "modules_may_import": {
          "type": "object",
          "description": "Map of module name -> array of modules it may import from",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "shared_layer": {
          "type": "string",
          "description": "Module/namespace that all modules can import from",
          "examples": ["core", "shared", "common"]
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security-specific rules and checks. Security is non-negotiable — even non-public apps must follow strict practices because exposure status can change, internal threats exist, and compliance may require it.",
      "properties": {
        "posture": {
          "type": "string",
          "enum": ["strict", "advisory"],
          "default": "strict",
          "description": "How security rules are enforced. 'strict': new code MUST meet all security rules — violations BLOCK. All new projects start here. 'advisory': existing patterns are respected, gaps are flagged as WARN with mitigation tasks generated — but the established codebase is not overridden. /init sets this automatically: empty/new projects get 'strict', existing codebases with established patterns get 'advisory' with a migration path toward strict."
        },
        "baseline_gaps": {
          "type": "array",
          "description": "Security gaps inherited from an existing codebase. Only populated when posture is 'advisory'. These are tracked debt — not exemptions.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Unique identifier (e.g., 'gap-auth-001')" },
              "category": {
                "type": "string",
                "enum": ["auth", "tenancy", "exposure", "injection", "secrets", "file-access", "csrf", "session"],
                "description": "Security domain"
              },
              "description": { "type": "string", "description": "What the gap is" },
              "scope": { "type": "string", "description": "Where it exists (file glob, module name, or 'project-wide')" },
              "affected_files": {
                "type": "array",
                "items": { "type": "string" },
                "description": "File patterns affected"
              },
              "mitigation": { "type": "string", "description": "Recommended fix approach" },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "status": { "type": "string", "enum": ["open", "in_progress", "resolved"], "default": "open" }
            }
          }
        },
        "checks": {
          "type": "array",
          "description": "Security checks the QC agent must perform",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "info", "block", "warn"],
                "default": "error",
                "description": "How this finding affects the QC verdict. 'error'/'block' triggers BLOCK, 'warning'/'warn' triggers WARN, 'info' is informational only. Prefer error/warning/info for v1.1 manifests — block/warn are accepted only for backwards compatibility with v1.0. /init always generates error/warning/info."
              },
              "description": { "type": "string" },
              "detect": { "type": "string", "description": "How to detect this issue" },
              "paths": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob patterns of files this check applies to. Absent or empty means all files."
              }
            }
          }
        },
        "sensitive_fields": {
          "type": "array",
          "description": "Field names that must never be exposed to frontend",
          "items": { "type": "string" },
          "examples": [["password", "remember_token", "api_token", "secret"]]
        }
      }
    },
    "rule_defaults": {
      "type": "object",
      "description": "Default severity settings for rule evaluation. Individual rules can override these via inline annotations. Omit to use tier defaults.",
      "properties": {
        "security_severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error",
          "description": "Default severity for security rules"
        },
        "architecture_severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "warning",
          "description": "Default severity for architecture rules"
        },
        "convention_severity": {
          "type": "string",
          "enum": ["warning", "info"],
          "default": "warning",
          "description": "Default severity for convention rules. Cannot be 'error' — conventions never BLOCK."
        }
      }
    }
  }
}
